# ─── Base de données (Supabase) ──────────────────────────────────────────────
# URL de connexion poolée (utilisée par Prisma en production / Edge)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"

# URL directe (utilisée uniquement pour les migrations Prisma — pas en production)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Clé secrète — générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# URL de déploiement (ex: https://pharmagest.vercel.app ou http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Serveur SMTP pour les alertes automatiques (Gmail, Brevo, Resend, etc.)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="votre-email@gmail.com"
SMTP_PASS="votre-mot-de-passe-application"

# Email de l'administrateur global (destinataire des alertes si la pharmacie
# n'a pas d'email propre)
EMAIL_ADMIN="admin@pharmagest.com"

# ─── Cron jobs (Vercel) ───────────────────────────────────────────────────────
# Secret partagé entre Vercel Cron et les routes /api/cron/*
# Générer avec : openssl rand -hex 32
# À ajouter dans Vercel → Settings → Environment Variables
CRON_SECRET="your-cron-secret-here"

# ─── Backup Backblaze B2 ─────────────────────────────────────────────────────
# Identifiants du bucket B2 pour les sauvegardes quotidiennes
# Créer un bucket nommé "pharmagest-backups" dans Backblaze B2
B2_KEY_ID="your-b2-key-id"
B2_APPLICATION_KEY="your-b2-application-key"
B2_BUCKET_ID="your-b2-bucket-id"
